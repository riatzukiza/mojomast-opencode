import { describe, expect, test, beforeEach, afterEach } from "bun:test"
import path from "path"
import { LspDiagnosticTool } from "../../src/tool/lsp-diagnostics"
import { Instance } from "../../src/project/instance"
import { tmpdir } from "../fixture/fixture"
import * as fs from "fs/promises"
import { mockDiagnostics, expectedDiagnosticOutputs, createMockDiagnosticsMap } from "./mocks/diagnostics"
import { mockLSPModule, setupLSPDiagnostics, setupErrorFile, setupCleanFile } from "./helpers/lsp-mock"

const ctx = {
  sessionID: "test",
  messageID: "",
  toolCallID: "",
  agent: "build",
  abort: AbortSignal.any([]),
  metadata: () => {},
}

const lspDiagnosticTool = await LspDiagnosticTool.init()

describe("tool.lsp_diagnostics", () => {
  let fixture: any

  beforeEach(async () => {
    fixture = await tmpdir()
  })

  afterEach(async () => {
    if (fixture) {
      await fixture[Symbol.asyncDispose]?.()
    }
  })

  test("should handle non-existent file", async () => {
    const restoreLSP = mockLSPModule()
    
    try {
      await Instance.provide({
        directory: fixture.path,
        fn: async () => {
          const nonExistentFile = path.join(fixture.path, "nonexistent.ts")
          setupCleanFile(nonExistentFile)

          const result = await lspDiagnosticTool.execute(
            { path: nonExistentFile },
            ctx
          )

          expect(result.title).toBe("nonexistent.ts")
          expect(result.output).toBe("No errors found")
          expect(result.metadata.diagnostics).toEqual({})
          expect(Object.keys(result.metadata.diagnostics)).toHaveLength(0)
        },
      })
    } finally {
      restoreLSP()
    }
  })
  })

  test("should handle clean file", async () => {
    const restoreLSP = mockLSPModule()
    
    try {
      await Instance.provide({
        directory: fixture.path,
        fn: async () => {
          const cleanFile = path.join(fixture.path, "clean.ts")
          await fs.writeFile(cleanFile, "const x: string = 'hello';")
          setupCleanFile(cleanFile)

          const result = await lspDiagnosticTool.execute(
            { path: cleanFile },
            ctx
          )

          expect(result.title).toBe("clean.ts")
          expect(result.output).toBe("No errors found")
          expect(result.metadata.diagnostics).toEqual({})
          expect(Object.keys(result.metadata.diagnostics)).toHaveLength(0)
        },
      })
    } finally {
      restoreLSP()
    }
  })

  test("should handle file with diagnostics", async () => {
    const restoreLSP = mockLSPModule()
    
    try {
      await Instance.provide({
        directory: fixture.path,
        fn: async () => {
          const errorFile = path.join(fixture.path, "error.ts")
          await fs.writeFile(errorFile, "const x: string = 123; // Type error")
          setupLSPDiagnostics(errorFile, [mockDiagnostics.typeError])

          const result = await lspDiagnosticTool.execute(
            { path: errorFile },
            ctx
          )

          expect(result.title).toBe("error.ts")
          expect(result.metadata.diagnostics).toBeDefined()
          
          // Verify diagnostics structure contains expected file
          expect(Object.keys(result.metadata.diagnostics)).toContain(errorFile)
          expect(result.metadata.diagnostics[errorFile]).toEqual([mockDiagnostics.typeError])
          
          // Verify output contains formatted diagnostics
          expect(typeof result.output).toBe("string")
          expect(result.output.length).toBeGreaterThan(0)
          expect(result.output).toContain(expectedDiagnosticOutputs.typeError)
        },
      })
    } finally {
      restoreLSP()
    }
  })
  })

  test("should handle relative paths", async () => {
    await Instance.provide({
      directory: fixture.path,
      fn: async () => {
        const testFile = path.join(fixture.path, "test.ts")
        await fs.writeFile(testFile, "const x: string = 'hello';")

        const result = await lspDiagnosticTool.execute({ path: "test.ts" }, ctx)

        expect(result.title).toBe("test.ts")
        expect(result.metadata.diagnostics).toBeDefined()
      },
    })
  })

  test("should handle absolute paths", async () => {
    await Instance.provide({
      directory: fixture.path,
      fn: async () => {
        const testFile = path.join(fixture.path, "test.ts")
        await fs.writeFile(testFile, "const x: string = 'hello';")

        const result = await lspDiagnosticTool.execute({ path: testFile }, ctx)

        expect(result.title).toBe("test.ts")
        expect(result.metadata.diagnostics).toBeDefined()
      },
    })
  })

  test("should handle multiple diagnostic types", async () => {
    await Instance.provide({
      directory: fixture.path,
      fn: async () => {
        const testFile = path.join(fixture.path, "mixed.ts")
        await fs.writeFile(
          testFile,
          `
          const x: string = 123; // Error
          const y = 456; // Warning (implicit any)
          // eslint-disable-next-line @typescript-eslint/no-unused-vars
          const z = "unused"; // Warning (unused variable)
        `,
        )

        const result = await lspDiagnosticTool.execute({ path: testFile }, ctx)

        expect(result.title).toBe("mixed.ts")
        expect(result.metadata.diagnostics).toBeDefined()

        // Should contain formatted output if diagnostics exist
        if (result.output !== "No errors found") {
          expect(typeof result.output).toBe("string")
        }
      },
    })
  })

  test("should handle file with syntax errors", async () => {
    await Instance.provide({
      directory: fixture.path,
      fn: async () => {
        const syntaxErrorFile = path.join(fixture.path, "syntax.ts")
        await fs.writeFile(syntaxErrorFile, "const x = ; // Invalid syntax")

        const result = await lspDiagnosticTool.execute({ path: syntaxErrorFile }, ctx)

        expect(result.title).toBe("syntax.ts")
        expect(result.metadata.diagnostics).toBeDefined()

        // Syntax errors should produce diagnostics
        if (result.output !== "No errors found") {
          expect(typeof result.output).toBe("string")
          expect(result.output.length).toBeGreaterThan(0)
        }
      },
    })
  })

  test("should handle empty file", async () => {
    await Instance.provide({
      directory: fixture.path,
      fn: async () => {
        const emptyFile = path.join(fixture.path, "empty.ts")
        await fs.writeFile(emptyFile, "")

        const result = await lspDiagnosticTool.execute({ path: emptyFile }, ctx)

        expect(result.title).toBe("empty.ts")
        expect(result.output).toBe("No errors found")
        expect(result.metadata.diagnostics).toBeDefined()
      },
    })
  })

  test("should handle file with only whitespace", async () => {
    await Instance.provide({
      directory: fixture.path,
      fn: async () => {
        const whitespaceFile = path.join(fixture.path, "whitespace.ts")
        await fs.writeFile(whitespaceFile, "   \n  \n   ")

        const result = await lspDiagnosticTool.execute({ path: whitespaceFile }, ctx)

        expect(result.title).toBe("whitespace.ts")
        expect(result.output).toBe("No errors found")
        expect(result.metadata.diagnostics).toBeDefined()
      },
    })
  })

  test("should handle file with comments only", async () => {
    await Instance.provide({
      directory: fixture.path,
      fn: async () => {
        const commentFile = path.join(fixture.path, "comment.ts")
        await fs.writeFile(
          commentFile,
          `
          // This is a comment
          /* Multi-line comment */
          /** JSDoc comment */
        `,
        )

        const result = await lspDiagnosticTool.execute({ path: commentFile }, ctx)

        expect(result.title).toBe("comment.ts")
        expect(result.output).toBe("No errors found")
        expect(result.metadata.diagnostics).toBeDefined()
      },
    })
  })

  test("should handle concurrent requests", async () => {
    await Instance.provide({
      directory: fixture.path,
      fn: async () => {
        const files = []

        // Create multiple files
        for (let i = 0; i < 3; i++) {
          const file = path.join(fixture.path, `file${i}.ts`)
          await fs.writeFile(file, `const x${i}: string = ${i};`)
          files.push(file)
        }

        // Execute diagnostics concurrently
        const promises = files.map((file) => lspDiagnosticTool.execute({ path: file }, ctx))

        const results = await Promise.all(promises)

        expect(results).toHaveLength(3)
        results.forEach((result, index) => {
          expect(result.title).toBe(`file${index}.ts`)
          expect(result.metadata.diagnostics).toBeDefined()
        })
      },
    })
  })

  test("should handle file outside working directory", async () => {
    await Instance.provide({
      directory: fixture.path,
      fn: async () => {
        const outsideFile = path.join("/tmp", "outside.ts")

        // Should handle gracefully or throw appropriate error
        const result = await lspDiagnosticTool.execute({ path: outsideFile }, ctx)

        // Either succeeds with diagnostics or fails gracefully
        expect(result).toBeDefined()
      },
    })
  })

  test("should validate required parameters", async () => {
    await Instance.provide({
      directory: fixture.path,
      fn: async () => {
        // Test with missing path parameter
        await expect(lspDiagnosticTool.execute({} as any, ctx)).rejects.toThrow()
      },
    })
  })

  test("should handle special characters in file path", async () => {
    await Instance.provide({
      directory: fixture.path,
      fn: async () => {
        const specialFile = path.join(fixture.path, "file-with-special.ts")
        await fs.writeFile(specialFile, "const x: string = 'hello';")

        const result = await lspDiagnosticTool.execute({ path: specialFile }, ctx)

        expect(result.title).toBe("file-with-special.ts")
        expect(result.metadata.diagnostics).toBeDefined()
      },
    })
  })
})
